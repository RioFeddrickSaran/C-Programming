    int n;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);}
    for(int start=0;start<n;start++){
        for(int end=start;end<n;end++){
            for(int i=end;i>=start;i--){
                printf("%d ",arr[i]);}
                printf("\n");}}}
