#include <stdio.h>
int main(){
    int n,sum,k;
    scanf("%d %d",&n,&k);
    int arr[n];
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);}
    for(int start=0;start<n;start++){
        for(int end=start;end<n;end++){
            sum=0;
            for(int i=start;i<=end;i++){
                sum+=arr[i];}
            if(sum==k){
                for(int i=start;i<=end;i++){
                    printf("%d ",arr[i]);}
                printf("\n");}}}}
