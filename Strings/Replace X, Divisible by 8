#include <stdio.h>
#include <string.h>
int main() {
    char s[100];
    scanf("%s",s);
    int x=0;
    for (int i=0;s[i]!='\0';i++){
        if(s[i]=='x'){
            x=i; 
            break;}}
    for (int j=0;j<=9;j++) {
        s[x]='0'+j;
        int n=0;
        for (int i=0;s[i]!='\0';i++){
            n=(s[i]-'0')+n*10;}
        if (n%8==0){
            printf("%d",j);
            return 0;}}}
