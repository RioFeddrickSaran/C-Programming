#include <stdio.h>
#include <string.h>
#include <ctype.h>
int main(){
    char str[100];
    scanf("%s",str);
    int len=strlen(str);
    for(int i=0;i<len;i++){
    if((str[i]=='a'||str[i]=='e'||str[i]=='i'||str[i]=='o'||str[i]=='u')||(str[i]=='A'||str[i]=='E'||str[i]=='I'||str[i]=='O'||str[i]=='U')){
        if(isupper(str[i+1])){
            str[i+1]=tolower(str[i+1]);}
        else{
            str[i+1]=toupper(str[i+1]);}}}
    printf("%s",str);
    }
    
