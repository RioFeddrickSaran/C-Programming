#include <stdio.h>
#include <string.h>
int main(){
    char s[100];
    int c=0,v=0;
    scanf("%s",s);
    int len=strlen(s);
    for(int start=0;start<len;start++){
     for(int end=start;end<len;end++){
        v=0,c=0;
      for(int i=start;i<=end;i++){
        if(s[i]!='A'&&s[i]!='a'&&s[i]!='E'&&s[i]!='e'&&s[i]!='I'&&s[i]!='i'&&s[i]!='O'&&
            s[i]!='o'&&s[i]!='U'&&s[i]!='u'){
                c++;}
        else{
            v++;}
          printf("%c ",s[i]);}
        printf(" - %d %d",c,v);
        printf("\n");}}}
