#include <stdio.h>
int main(){
    int n,m,sum1=0,sum2=0;
    scanf("%d %d",&n,&m);
    for(int i=1;i<n;i++){
        if(n%i==0)
        sum1+=i;}
    for(int i=1;i<m;i++){
        if(m%i==0)
        sum2+=i;}
    if(n/sum1==m/sum2){
        printf("Friendly pair");}
    else{
        printf("Not a friendly pair");}}
