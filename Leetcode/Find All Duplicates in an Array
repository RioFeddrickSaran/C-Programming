#include<stdio.h>
#include<stdlib.h>
int*findDuplicates(int*nums,int numsSize,int*returnSize){
int*ans=malloc(numsSize*sizeof(int));
int count=0;
char freq[100001]={0};
for(int i=0;i<numsSize;i++)freq[nums[i]]++;
for(int i=1;i<=numsSize;i++)if(freq[i]==2)ans[count++]=i;
*returnSize=count;
return ans;}
int main(){
int n;
scanf("%d",&n);
int*nums=malloc(n*sizeof(int));
for(int i=0;i<n;i++)scanf("%d",&nums[i]);
int returnSize;
int*ans=findDuplicates(nums,n,&returnSize);
for(int i=0;i<returnSize;i++)printf("%d ",ans[i]);
free(nums);
free(ans);}
