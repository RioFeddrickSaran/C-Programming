#include<stdio.h>
int findMaxConsecutiveOnes(int*nums,int numsSize){
int ml=0,cl=0;
for(int i=0;i<numsSize;i++){
if(nums[i]==1){
cl++;
if(cl>ml)ml=cl;}
else cl=0;}
return ml;}
int main(){
int n;
scanf("%d",&n);
int nums[n];
for(int i=0;i<n;i++)scanf("%d",&nums[i]);
printf("%d",findMaxConsecutiveOnes(nums,n));}
