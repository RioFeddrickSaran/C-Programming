#include <stdio.h>
int main(){
   int n,m;
   scanf("%d %d",&n,&m);
   int arr[n][m];
   for(int i=0;i<n;i++){
       for(int j=0;j<m;j++){
           scanf("%d",&arr[i][j]);}}
    int oddsum=0,evensum=0;
    for(int i=0;i<n;i++){
       for(int j=0;j<m;j++){
           if(arr[i][j]%2==0){
               evensum=evensum+arr[i][j];}
            else{
            oddsum=oddsum+arr[i][j];}}}
    printf("%d=Odd sum\n%d=Even sum",oddsum,evensum);}
